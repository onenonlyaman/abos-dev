{
  "name": "abos",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "packages/api",
    "packages/web"
  ],
  "scripts": {
    "dev:api": "npm run start:dev -w packages/api",
    "dev:web": "npm run dev -w packages/web",
    "build:api": "npm run build -w packages/api",
    "build:web": "npm run build -w packages/web",
    "migrate": "npm run prisma:migrate -w packages/api"
  },
  "allowScripts": {
    "@nestjs/core@10.4.22": true,
    "@prisma/client@5.22.0": true,
    "@prisma/engines@5.22.0": true,
    "msgpackr-extract@3.0.4": true,
    "prisma@5.22.0": true
  }
}
